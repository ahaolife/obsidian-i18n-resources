                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Render math in display mode, which puts the math in display style (so \\int and \\sum are large, for example), and centers the math on the page on its own line.",
                    "target": "以显示模式渲染数学公式，这会使公式使用显示样式（例如 \\int 和 \\sum 会更大），并将公式在页面上单独成行居中显示。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Determines the markup language of the output.",
                    "target": "确定输出的标记语言。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Render display math in leqno style (left-justified tags).",
                    "target": "以 leqno 样式渲染显示公式（标签左对齐）。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Render display math flush left.",
                    "target": "将显示公式左对齐渲染。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Makes \\color behave like LaTeX's 2-argument \\textcolor, instead of LaTeX's one-argument \\color mode change.",
                    "target": "使 \\color 的行为类似于 LaTeX 的双参数 \\textcolor，而不是 LaTeX 的单参数 \\color 模式切换。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Turn on strict / LaTeX faithfulness mode, which throws an error if the input uses features that are not supported by LaTeX.",
                    "target": "开启严格/LaTeX 忠实模式，当输入使用 LaTeX 不支持的特性时会报错。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Trust the input, enabling all HTML features such as \\url.",
                    "target": "信任输入，启用所有 HTML 功能，如 \\url。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "Limit the number of macro expansions to the specified number, to prevent e.g. infinite macro loops. If set to Infinity, the macro expander will try to fully expand as in LaTeX.",
                    "target": "将宏展开次数限制为指定数量，以防止例如无限宏循环。如果设为 Infinity，宏展开器将像 LaTeX 一样尝试完全展开。"
                },
                {

                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "The size of the generated images. Must be one of 1024x1024, 1536x1024, 1024x1536, or auto.",
                    "target": "生成图像的尺寸。必须为 1024x1024、1536x1024、1024x1536 或 auto 之一。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "The quality of the image that will be generated. Higher quality takes longer and costs more.",
                    "target": "生成图像的质量。质量越高，耗时越长且成本越高。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "Maximum number of tokens in the response. Set to 0 to use the model's default. Higher values allow longer responses.",
                    "target": "响应中的最大 token 数。设为 0 使用模型默认值。数值越高，可生成更长的响应。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "Defaults to 0. Number between -2.0 and 2.0. Positive values penalize new tokens based on their existing frequency in the text so far, decreasing the model's likelihood to repeat the same line verbatim.",
                    "target": "默认值为 0。取值范围为 -2.0 到 2.0。正值会根据新 token 在当前文本中的已有频率进行惩罚，从而降低模型逐字重复同一行的可能性。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "Defaults to false. Whether to return log probabilities of the output tokens or not. If true, returns the log probabilities of each output token returned in the content of message.",
                    "target": "默认值为 false。是否返回输出 token 的对数概率。若为 true，则在 message 的内容中返回每个输出 token 的对数概率。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "An integer between 0 and 5 specifying the number of most likely tokens to return at each token position, each with an associated log probability. logprobs must be set to true if this parameter is used.",
                    "target": "一个介于 0 到 5 的整数，用于指定在每个 token 位置返回的最可能 token 数量，每个都带有关联的对数概率。使用此参数时必须将 logprobs 设为 true。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",
                    "source": "Defaults to 0. Number between -2.0 and 2.0. Positive values penalize new tokens based on whether they appear in the text so far, increasing the model's likelihood to talk about new topics.",
                    "target": "默认值为 0。取值范围为 -2.0 到 2.0。正值会根据新 token 是否出现在当前文本中进行惩罚，从而提高模型谈论新话题的可能性。"
                },
                {
                    "type": "CallExpression",
                    "name": "setDesc",

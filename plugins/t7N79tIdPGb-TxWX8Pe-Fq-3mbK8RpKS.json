                    "source": "Enable/disable Obsidian debug mode.",
                    "target": "启用/禁用 Obsidian 调试模式。"
                },
                {
                    "type": "CallExpression",
                    "name": "appendText",
                    "source": "When enabled, inline source maps will not be stripped from loaded plugins.",
                    "target": "启用后，内联源映射将不会从已加载的插件中被移除。"
                },
                {
                    "type": "CallExpression",
                    "name": "appendText",
                    "source": "⚠️ This setting change will reload the app.",
                    "target": "⚠️ 此设置更改将重新加载应用。"
                },
                {
                    "type": "CallExpression",
                    "name": "appendText",
                    "source": "Configure the debug namespaces.",
                    "target": "配置调试命名空间。"
                },
                {
                    "type": "CallExpression",
                    "name": "appendText",
